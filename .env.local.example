# ─── NIBIS ERP API (server-side — NIKAD ne izlaži u browser) ──────────────────
NIBIS_API_URL=https://api.nextvision.ba/integration/robno-materijalno
NIBIS_API_KEY=YOUR_API_KEY_OVDJE
NIBIS_COMPANY_YEAR=2026

# ─── Konfiguracija webshopa (NEXT_PUBLIC_ = vidljivo u browseru) ───────────────

# Naziv webshopa — mijenja se ovdje!
NEXT_PUBLIC_SHOP_NAME=Moj WebShop

# Kratki opis
NEXT_PUBLIC_SHOP_DESCRIPTION=Online narudžba robe

# Kontakt email (opcionalno, prikazuje se u footeru)
NEXT_PUBLIC_CONTACT_EMAIL=

# Organizaciona jedinica ID iz NIBIS-a
NEXT_PUBLIC_ORG_JED_ID=1

# Naziv OJ za prikaz u headeru
NEXT_PUBLIC_ORG_JED_NAZIV=Sarajevo Centar

# Tip cijene: mpcijena (maloprodajna) | vpcijena (veleprodajna)
NEXT_PUBLIC_TIP_CIJENE=mpcijena

# Broj artikala po stranici
NEXT_PUBLIC_PER_PAGE=24

# Da li prikazivati artikle bez stanja (true/false)
NEXT_PUBLIC_PRIKAZI_NEMA_STANJA=true

# Logotip — stavi fajl u /public/logo.png i ovdje upiši /logo.png
# Ili koristi vanjski URL
NEXT_PUBLIC_LOGO_URL=

# Cloudinary (za upload slika artikala — opcionalno)
NEXT_PUBLIC_CLOUDINARY_CLOUD=

# ─── Supabase ──────────────────────────────────────────────────────────────────
# Nađi na: supabase.com → tvoj projekt → Settings → API

# Project URL (javno — safe za browser)
NEXT_PUBLIC_SUPABASE_URL=https://TVOJ_PROJEKT.supabase.co

# Anon key (javno — safe za browser, ograničene privilegije)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...

# Service role key (TAJNO — samo server-side, nikad u browser!)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...

# ─── Cron zaštita ─────────────────────────────────────────────────────────────
# Izmisli bilo koji string — npr: abc123tajnilozinka
CRON_SECRET=IZMISLI_NEKI_TAJNI_STRING

# ─── Email (Resend) ────────────────────────────────────────────────────────────
# Besplatno do 3000 emaila/mj — https://resend.com
# Ako nije postavljeno, emailovi se ne šalju (webshop i dalje radi)
RESEND_API_KEY=re_xxxxxxxxxxxx

# Email adresa s koje se šalju emailovi (mora biti verificirana domena na Resend)
EMAIL_FROM=narudzbe@tvoja-domena.ba

# Email admina — prima obavijesti o svakoj narudžbi
EMAIL_ADMIN=admin@tvoja-domena.ba
